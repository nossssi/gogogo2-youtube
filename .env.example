# 루트에 .env 로 복사해서 사용: cp .env.example .env
#
# ★ 기본 파이프라인(flow 무료 이미지 + Vrew 반수동 TTS + CapCut 렌더)은
#   API 키가 하나도 필요 없다. 아래 키는 유료 엔진을 명시적으로 켤 때만 등록.

# 이미지 생성 — settings.json image.engine="gemini" 지정 시에만 필요 (유료, 실수 과금 주의)
GEMINI_API_KEY=

# TTS — settings.json tts.engine="elevenlabs" 지정 시에만 필요 (유료, 기본은 vrew)
ELEVENLABS_API_KEY=
