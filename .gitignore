# ══════════════════════════════════════════════════════════
# 원칙: 레포 = 파이프라인(스킬+스크립트+채널 config).
#       프로젝트 작업물·미디어·비밀정보는 각자 로컬.
# ══════════════════════════════════════════════════════════

# ── 비밀정보 ──────────────────────────────────────────────
.env
channels/*/config/youtube-api/

# ── 개인 작업물: 프로젝트는 전체 제외 ──────────────────────
channels/*/projects/
renders/

# ── research: 공유 대장(topic_log)·벤치마킹(refs)·제안서는 커밋,
#    일회성 스캔 리포트는 로컬 ──────────────────────────────
channels/*/research/scan_*

# ── python ────────────────────────────────────────────────
.venv/
__pycache__/
*.pyc

# ── node ──────────────────────────────────────────────────
node_modules/

# ── OS / 에디터 / Claude 로컬 설정 ────────────────────────
.DS_Store
.claude/settings.local.json
